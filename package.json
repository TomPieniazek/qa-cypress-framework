{
  "name": "qa-cypress-framework",
  "version": "1.0.0",
  "description": "Cypress framework for testing sample web app",
  "homepage": "https://github.com/TomPieniazek/qa-cypress-framework#readme",
  "bugs": {
    "url": "https://github.com/TomPieniazek/qa-cypress-framework/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TomPieniazek/qa-cypress-framework.git"
  },
  "license": "ISC",
  "author": "TomPieniazek",
  "type": "commonjs",
  "scripts": {
    "cy:open": "npx cypress open",
    "cy:run": "npx cypress run",
    "test": "npm run cy:run",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results",
    "app:up": "docker run --name rolnopol-app -p 3000:3000 -d jaktestowac/rolnopol:1.0.113",
    "app:down": "docker stop rolnopol-app && docker rm rolnopol-app"
  },
  "devDependencies": {
    "@faker-js/faker": "10.3.0",
    "allure-commandline": "2.38.0",
    "allure-cypress": "3.6.0",
    "cypress": "15.11.0",
    "eslint": "10.0.3",
    "eslint-plugin-cypress": "6.2.0",
    "prettier": "3.8.1"
  }
}
